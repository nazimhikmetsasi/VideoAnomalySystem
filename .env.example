# Kafka
KAFKA_ENABLED=true
KAFKA_BOOTSTRAP_SERVERS=127.0.0.1:9092
KAFKA_TOPIC=video-stream
KAFKA_ANOMALY_TOPIC=anomaly-events
KAFKA_VERIFIED_TOPIC=verified-anomalies

# Kamera
CAMERA_SOURCE=0
CAMERA_ID=cam_01
FRAME_WIDTH=640
FRAME_HEIGHT=480
TARGET_FPS=30

# YOLOv8
YOLO_MODEL_PATH=yolov8n.pt
YOLO_CONF_THRESHOLD=0.25
YOLO_IOU_THRESHOLD=0.45
USE_GPU=true

# DeepSORT
DEEPSORT_MAX_AGE=30
DEEPSORT_N_INIT=3

# Pose (YOLOv8-pose — MediaPipe yerine, Turkce karakterli yollarda uyumlu)
POSE_MODEL_PATH=yolov8n-pose.pt
POSE_MIN_DETECTION_CONF=0.25

# Kinematik / Anomali esikleri
KINEMATICS_WINDOW_SIZE=30
FALL_VERTICAL_VELOCITY=120
FALL_SPINE_ANGLE=30
RUN_HORIZONTAL_SPEED=90
ANOMALY_COOLDOWN_SEC=12
MIN_KINEMATICS_SAMPLES=8
ENABLE_PRESENCE_ALERT=false
PRESENCE_COOLDOWN_SEC=30

# Spark kayan pencere
SPARK_WINDOW_SEC=10
SPARK_MIN_EVENTS=1

# Yasakli bolge
ZONE_CONFIG_PATH=config/zones.json

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=mcbu_user
POSTGRES_PASSWORD=anomaly_password
POSTGRES_DB=anomaly_db
DATABASE_URL=postgresql://mcbu_user:anomaly_password@localhost:5432/anomaly_db

# MongoDB
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_DB=anomaly_metrics

# LLM (gemini veya openai)
# Anahtar: https://aistudio.google.com/apikey
LLM_PROVIDER=gemini
GEMINI_API_KEY=
OPENAI_API_KEY=
LLM_MODEL=gemini-2.0-flash

# API
API_HOST=0.0.0.0
API_PORT=8000
API_NOTIFY_URL=http://127.0.0.1:8000/api/internal/alert
API_NOTIFY_RETRIES=2

# Log (RotatingFileHandler — max 10MB, 3 yedek)
LOG_LEVEL=INFO
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=3
