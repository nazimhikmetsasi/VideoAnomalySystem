# Kafka
KAFKA_ENABLED=true
KAFKA_BOOTSTRAP_SERVERS=127.0.0.1:9092
KAFKA_TOPIC=video-stream
KAFKA_ANOMALY_TOPIC=anomaly-events
KAFKA_VERIFIED_TOPIC=verified-anomalies

# Kamera
CAMERA_SOURCE=0
CAMERA_INPUT_TYPE=auto
# auto | webcam | rtsp | file
# RTSP ornek: rtsp://admin:sifre@192.168.1.64:554/stream1
RTSP_BUFFER_SIZE=1
CAMERA_ID=cam_01
FRAME_WIDTH=640
FRAME_HEIGHT=480
TARGET_FPS=30

# YOLOv8
YOLO_MODEL_PATH=yolov8n.pt
YOLO_CONF_THRESHOLD=0.25
YOLO_IOU_THRESHOLD=0.45
USE_GPU=true

# YOLO fine-tune (run_finetune.bat)
FINETUNE_EPOCHS=30
FINETUNE_IMGSZ=640
FINETUNE_BATCH=8
FINETUNE_PROJECT=runs/detect
FINETUNE_NAME=pilot_person

# DeepSORT
DEEPSORT_MAX_AGE=30
DEEPSORT_N_INIT=3

# Pose (YOLOv8-pose — MediaPipe yerine, Turkce karakterli yollarda uyumlu)
POSE_MODEL_PATH=yolov8n-pose.pt
POSE_MIN_DETECTION_CONF=0.25

# Kinematik / Anomali esikleri (640x480 webcam — px/sn normalize)
KINEMATICS_WINDOW_SIZE=30
RUN_HORIZONTAL_SPEED=45
FALL_VERTICAL_VELOCITY=55
FALL_SPINE_ANGLE=45
ANOMALY_COOLDOWN_SEC=8
MIN_KINEMATICS_SAMPLES=4
ENABLE_PRESENCE_ALERT=false
PRESENCE_COOLDOWN_SEC=30
ZONE_BBOX_FALLBACK=false

# Spark kayan pencere
STREAM_MODE=python
SPARK_WINDOW_SEC=10
SPARK_MIN_EVENTS=2
SPARK_MASTER=local[*]
SPARK_CHECKPOINT=spark_checkpoint
SPARK_KAFKA_PACKAGE=org.apache.spark:spark-sql-kafka-0-10_2.12:3.5.0

# Yasakli bolge
ZONE_CONFIG_PATH=config/zones.json

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=mcbu_user
POSTGRES_PASSWORD=anomaly_password
POSTGRES_DB=anomaly_db
DATABASE_URL=postgresql://mcbu_user:anomaly_password@localhost:5432/anomaly_db

# MongoDB
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_DB=anomaly_metrics

# LLM (gemini veya openai)
# Anahtar: https://aistudio.google.com/apikey
LLM_PROVIDER=gemini
GEMINI_API_KEY=
OPENAI_API_KEY=
LLM_MODEL=gemini-2.0-flash

# API
API_HOST=0.0.0.0
API_PORT=8000
API_NOTIFY_URL=http://127.0.0.1:8000/api/internal/alert
API_NOTIFY_RETRIES=2

# Auth (JWT)
AUTH_ENABLED=true
AUTH_SECRET=mcbu-dev-secret-degistirin
AUTH_TOKEN_HOURS=24
AUTH_USERS_FILE=config/users.json

# Firebase mobil bildirim
FCM_ENABLED=false
FCM_CREDENTIALS_PATH=config/firebase-service-account.json
FCM_TOPIC=anomalies
FCM_DEVICE_TOKENS=
FCM_SERVER_KEY=

# Coklu kamera
CAMERAS_CONFIG_PATH=config/cameras.json

# Log (RotatingFileHandler — max 10MB, 3 yedek)
LOG_LEVEL=INFO
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=3
