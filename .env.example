# Kafka
KAFKA_ENABLED=true
KAFKA_BOOTSTRAP_SERVERS=127.0.0.1:9092
KAFKA_TOPIC=video-stream
KAFKA_ANOMALY_TOPIC=anomaly-events
KAFKA_VERIFIED_TOPIC=verified-anomalies

# Kamera
CAMERA_SOURCE=0
CAMERA_INPUT_TYPE=auto
# auto | webcam | rtsp | file
# RTSP ornek: rtsp://admin:sifre@192.168.1.64:554/stream1
RTSP_BUFFER_SIZE=1
CAMERA_ID=cam_01
FRAME_WIDTH=960
FRAME_HEIGHT=540
TARGET_FPS=30

# YOLOv8
# Fine-tune sonrasi: runs/detect/pilot_person/weights/best.pt
YOLO_MODEL_PATH=yolov8n.pt
YOLO_CONF_THRESHOLD=0.10
YOLO_IOU_THRESHOLD=0.45
USE_GPU=true

# YOLO fine-tune (prepare_finetune_data.py + run_finetune.bat)
FINETUNE_EPOCHS=20
FINETUNE_IMGSZ=640
FINETUNE_BATCH=8
FINETUNE_PROJECT=runs/detect
FINETUNE_NAME=pilot_person

# DeepSORT
DEEPSORT_MAX_AGE=30
DEEPSORT_N_INIT=1

# ReID galeri (uniformali kisiler icin margin / reacquire kritik)
REID_MIN_SIM=0.82
REID_MIN_MARGIN=0.035
REID_TIE_EPS=0.03
REID_REACQUIRE_FRAMES=60
REID_SOFT_REACQUIRE=8
REID_SOFT_DIST_PX=70
REID_GALLERY_PATH=data/reid_gallery.npz

# Pose (YOLOv8-pose — MediaPipe yerine, Turkce karakterli yollarda uyumlu)
POSE_MODEL_PATH=yolov8n-pose.pt
POSE_MIN_DETECTION_CONF=0.25

# Kinematik / Anomali esikleri (yanlis alarm azaltildi)
KINEMATICS_WINDOW_SIZE=30
RUN_HORIZONTAL_SPEED=65
FALL_VERTICAL_VELOCITY=70
FALL_SPINE_ANGLE=40
WALK_SPEED_MIN=15
MOTION_CONFIRM_FRAMES=5
REQUIRE_MOTION_CONFIRM=true
MIN_RUN_CONFIDENCE=0.55
ZONE_DWELL_FRAMES=10
ANOMALY_COOLDOWN_SEC=18
MIN_KINEMATICS_SAMPLES=8
ENABLE_PRESENCE_ALERT=false
PRESENCE_COOLDOWN_SEC=30
ZONE_BBOX_FALLBACK=false

# Spark kayan pencere
STREAM_MODE=python
SPARK_WINDOW_SEC=10
SPARK_MIN_EVENTS=2
SPARK_MASTER=local[*]
SPARK_CHECKPOINT=spark_checkpoint
SPARK_KAFKA_PACKAGE=org.apache.spark:spark-sql-kafka-0-10_2.12:3.5.0

# Yasakli bolge
ZONE_CONFIG_PATH=config/zones.json
# Kur/Birak: home=Evde (bildirim yok), away=Koruma
SECURITY_MODE_PATH=config/security_mode.json

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=mcbu_user
POSTGRES_PASSWORD=anomaly_password
POSTGRES_DB=anomaly_db
DATABASE_URL=postgresql://mcbu_user:anomaly_password@localhost:5432/anomaly_db

# MongoDB
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_DB=anomaly_metrics

# LLM (gemini veya openai)
# Anahtar: https://aistudio.google.com/apikey
LLM_PROVIDER=gemini
GEMINI_API_KEY=
OPENAI_API_KEY=
LLM_MODEL=gemini-flash-lite-latest

# API
API_HOST=0.0.0.0
API_PORT=8000
API_NOTIFY_URL=http://127.0.0.1:8000/api/internal/alert
API_NOTIFY_RETRIES=2

# Auth (JWT)
AUTH_ENABLED=true
AUTH_SECRET=mcbu-dev-secret-degistirin
AUTH_TOKEN_HOURS=24
AUTH_USERS_FILE=config/users.json

# Firebase (opsiyonel — ozel Android uygulama)
FCM_ENABLED=false
FCM_CREDENTIALS_PATH=config/firebase-service-account.json
FCM_TOPIC=anomalies
FCM_DEVICE_TOKENS=
FCM_SERVER_KEY=

# --- Telefona bildirim (uygulama YOK) ---
# 1) Telegram (onerilen, ucretsiz)
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# 2) SMS (Netgsm veya Twilio — ucretli)
SMS_ENABLED=false
SMS_PROVIDER=netgsm
SMS_TO=
NETGSM_USER=
NETGSM_PASS=
NETGSM_HEADER=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# Coklu kamera
CAMERAS_CONFIG_PATH=config/cameras.json

# Log (RotatingFileHandler — max 10MB, 3 yedek)
LOG_LEVEL=INFO
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=3
